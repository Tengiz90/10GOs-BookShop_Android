<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/anti_line"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:minHeight="340dp"
        app:cardBackgroundColor="@color/slight_more_line"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/frontCoverIV"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                android:src="@drawable/book"
                android:contentDescription="image of the book" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/textsWrapper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/bookNameTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginVertical="10dp"
                    android:text="The Witcher: The Last Wish"
                    android:textColor="@color/line"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:minLines="3" />

                <TextView
                    android:id="@+id/bookAuthorTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:gravity="center_horizontal"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="10dp"
                    android:minLines="3"
                    android:text="Andrzej Sapkowski"
                    android:textColor="@color/line"
                    android:textIsSelectable="true" />
                <TextView
                    android:id="@+id/bookLanguageTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="10dp"
                    android:minLines="1"
                    android:layout_marginStart="10dp"
                    android:text="Language: English"
                    android:textColor="@color/line"
                    android:textIsSelectable="true"/>
                <TextView
                    android:id="@+id/bookAvailableQuantityTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="start"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:minLines="1"
                    android:text="1 Available"
                    android:textColor="@color/line"
                    android:textIsSelectable="true" />

                <Button
                    android:id="@+id/addToCartBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:layout_marginHorizontal="12dp"
                    android:backgroundTint="@color/primary_light"
                    android:text="Add to Cart" />

            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.appcompat.widget.LinearLayoutCompat>

    </com.google.android.material.card.MaterialCardView>
</androidx.appcompat.widget.LinearLayoutCompat>